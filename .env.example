# PostgreSQL — OLTP (mutable relational state)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vigilant
POSTGRES_USER=vigilant
POSTGRES_PASSWORD=vigilant

# ClickHouse — OLAP (append-only analytics)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=vigilant
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Caddy (only used by the `prod` compose profile)
# CADDY_DOMAIN=vigilant-api.duckdns.org
# CADDY_UI_DOMAIN=vigilant-ui.duckdns.org